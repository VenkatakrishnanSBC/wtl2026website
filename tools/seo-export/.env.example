# Copy to .env and fill in. NEVER commit .env or credential JSON files.

# NUMERIC GA4 property ID — NOT the measurement id (G-QVG2LR3XV1).
# Find it: GA4 Admin -> Property -> Property Settings -> "Property ID".
GA4_PROPERTY_ID=

# GSC property. Use EXACTLY what Search Console shows:
#   URL-prefix property:  https://worldtransgroup.com/   (trailing slash required)
#   Domain property:      sc-domain:worldtransgroup.com
GSC_SITE_URL=https://worldtransgroup.com/

# --- Auth option A (ALL-TIME): refresh token against your OWN OAuth client ---
# One-time setup (no hourly re-paste, no service-account grant):
#  1. GCP Console -> OAuth consent screen: User type External, Publishing status
#     "In production" (so the refresh token doesn't expire), add your email.
#  2. Credentials -> Create OAuth client ID -> "Web application" -> add redirect
#     URI  https://developers.google.com/oauthplayground  -> copy Client ID+secret.
#  3. OAuth Playground -> gear icon -> "Use your own OAuth credentials" -> paste
#     them. Step 1 scopes:
#       https://www.googleapis.com/auth/analytics.readonly https://www.googleapis.com/auth/webmasters
#     Authorize -> Exchange -> copy the REFRESH token.
# Set all three; the CLI then auto-mints access tokens forever.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REFRESH_TOKEN=

# --- Auth option B: OAuth access token (OAuth Playground default client) ---
# Authorize at https://developers.google.com/oauthplayground with scopes
# analytics.readonly + webmasters.readonly, exchange for tokens, paste the
# ACCESS token here. Expires ~1h; regenerate as needed. Takes precedence over B.
#
# NOTE: to RESUBMIT a sitemap (`gsc-sitemap --resubmit`) the token must include
# the read-WRITE scope instead of webmasters.readonly:
#   https://www.googleapis.com/auth/webmasters
# (read-only commands — queries, pages, inspect, sitemap list — don't need it.)
OAUTH_ACCESS_TOKEN=

# Optional quota project for user-token calls (set if Google asks for one).
# QUOTA_PROJECT=

# --- Auth option B: service-account JSON key ---
# Requires granting the SA email access in GA4 + GSC UIs.
# Keep keys in tools/seo-export/credentials/ — that directory is gitignored.
GOOGLE_APPLICATION_CREDENTIALS=credentials/wtl-seo-export.json
